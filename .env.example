# Web dashboard data source mode:
# - bucket_compute (default): compute report live from GCS summary.csv files.
# - remote: read prebuilt report JSON from RESULTS_REPORT_URL.
# - local: read local results/model-comparison-report.json.
# - auto: try bucket_compute -> remote -> local.
RESULTS_SOURCE_MODE=bucket_compute

# Bucket source for bucket_compute mode.
RESULTS_BUCKET_NAME=levante-bench
RESULTS_BUCKET_PREFIX=results

# Optional remote prebuilt report URL (used in remote/auto mode).
RESULTS_REPORT_URL=

{
  "version": 2,
  "functions": {
    "api/results-report.js": {
      "maxDuration": 60
    },
    "api/parser-glitch-report.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/results-report",
      "destination": "/api/results-report.js"
    },
    {
      "source": "/api/parser-glitch-report",
      "destination": "/api/parser-glitch-report.js"
    },
    {
      "source": "/",
      "destination": "/results-dashboard.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
